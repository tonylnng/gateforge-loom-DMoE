# ──────────────────────────────────────────────────────────────────────────
# GateForge-Loom-DMoE — single-box DGX (GB10) .env
# Copy to `.env` and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────────────────

# ===== Shared internal auth (must be identical across all services) =========
# Generate once:  openssl rand -hex 32
INTERNAL_API_TOKEN=replace-me-with-openssl-rand-hex-32

# ===== Brain — claude-gateway (routes to Anthropic via Vercel AI Gateway) ===
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/anthropic
AI_GATEWAY_API_KEY=replace-me-vercel-ai-gateway-key
BRAIN_MODEL=claude-opus-4

# ===== Knowledge — hermes-dmoe (true parametric DMoE, self-hosted, USES GPU) =
# STUB_MODE=1 boots with canned experts (no model load) for a first smoke test.
# Flip to 0 for real weight-level injection once the bank + base model are set.
STUB_MODE=1
EXPERT_BANK_DIR=/data/experts
TOP_K=3
TU_THRESHOLD=2.0
BASE_MODEL=meta-llama/Llama-3.2-1B-Instruct
# Hugging Face token to pull gated base models
HF_TOKEN=

# ===== Memory — postgres / pgvector =========================================
POSTGRES_USER=loom
POSTGRES_PASSWORD=replace-me-strong-db-password
POSTGRES_DB=hermes

# ===== Orchestrator — n8n ===================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-me-n8n-password
# Set to your Tailscale MagicDNS name or LAN host so webhooks resolve correctly
N8N_HOST=dgx.tailnet-name.ts.net
N8N_PROTOCOL=https
WEBHOOK_URL=https://dgx.tailnet-name.ts.net/

# ===== Logging ==============================================================
LOG_LEVEL=INFO
